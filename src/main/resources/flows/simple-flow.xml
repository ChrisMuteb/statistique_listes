<?xml version="1.0" encoding="UTF-8"?>
<flow xmlns="http://www.springframework.org/schema/webflow"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="
        http://www.springframework.org/schema/webflow
        http://www.springframework.org/schema/webflow/spring-webflow-2.4.xsd"
      start-state="home">



    <view-state id="home" view="home">
        <on-render>
            <evaluate expression="statistiqueformaction.setupForm" result="flowScope.statistiqueform" />
        </on-render>
        <transition on="submit" to="soumettre" />

    </view-state>

    <action-state id="soumettre">
        <evaluate expression="statistiqueformaction.soumettre" result="flowScope.statistiqueform" />
        <transition on="success" to="home" />
        <transition on="error" to="homeinit.view" />
    </action-state>

    <view-state id="homeinit.view" view="home" >
        <transition on="submit" to="soumettre" />
    </view-state>

    <bean-import resource="simple-flow-beans.xml" />
</flow>